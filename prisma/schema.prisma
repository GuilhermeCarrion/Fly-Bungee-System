generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum AppointmentStatus {
  BOOKED //marcado sem confirmação
  CONFIRMED //confirmado presença
  RESCHEDULED // remarcado
  CANCELLED //Cancelado
}

enum ClassSessionStatus {
  OPEN
  CANCELLED
  COMPLETED
}

model Academy {
  id String @id @default(uuid())
  name String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 

  users User[]
  students Student[]
  professors Professor[]
  classSessions ClassSession[]
  appointments Appointment[]
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  role Role @default(USER)
  academyId String
  active Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id])
  sessions Session[]
}

model Session {
  id String @id @default(uuid())
  userId String
  token String @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id String @id @default(uuid())
  name String
  phone String
  cpf String @unique
  email String?
  birthDate DateTime?
  academyId String

  registredAt DateTime @default(now())

  heightCm Int?
  weightKg Decimal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id])
  appointments Appointment[]
}

model Professor {
  id String @id @default(uuid())
  name String
  phone String
  cpf String @unique
  academyId String

  active Boolean @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)
  classSession ClassSession[]
}

model ClassSession {
  id String @id @default(uuid())
  academyId String
  professorId String
  name String
  startAt DateTime
  capacity Int
  status ClassSessionStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)
  professor Professor @relation(fields: [professorId], references: [id], onDelete: Restrict)
  appointments Appointment[]

  @@unique([academyId, startAt]) //Evita duas aulas no mesmo horario
}

model Appointment {
  id String @id @default(uuid())
  academyId String
  studentId String
  classSessionId String

  status AppointmentStatus @default(BOOKED)
  
  confirmedAt DateTime?
  cancelledAt DateTime?
  rescheduledAt DateTime?
  rescheduleFromId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId], references: [id], onDelete: Restrict)
  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Restrict)

  // Regras de estrutura
  @@unique([classSessionId, studentId]) //Aluno não pode agendar 2x a msm aula
  @@index([academyId, classSessionId])
  @@index([academyId, studentId])
}


